import json
import math
import os
import re
import sys

root = sys.argv[1]
json_path = sys.argv[2]
root_real = os.path.realpath(root)

with open(json_path, "r", encoding="utf-8") as handle:
    mailboxes = json.load(handle)

if not isinstance(mailboxes, list) or len(mailboxes) > 1000:
    raise SystemExit(78)

email_re = re.compile(r"^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$")

def safe_mailbox_path(email: str) -> str:
    if not isinstance(email, str) or not email_re.fullmatch(email):
        raise SystemExit(70)
    local, domain = email.lower().split("@", 1)
    mailbox_path = os.path.realpath(os.path.join(root_real, domain, local))
    if mailbox_path == root_real or not mailbox_path.startswith(root_real + os.sep):
        raise SystemExit(74)
    return mailbox_path

def maildirsize_bytes(mailbox_path: str) -> int:
    path = os.path.join(mailbox_path, "maildirsize")
    total = 0
    try:
        with open(path, "r", encoding="utf-8", errors="ignore") as handle:
            for index, line in enumerate(handle):
                if index == 0:
                    continue
                parts = line.strip().split()
                if not parts:
                    continue
                try:
                    size = int(parts[0])
                except ValueError:
                    continue
                if size > 0:
                    total += size
    except OSError:
        return 0
    return max(0, total)

def message_file_bytes(mailbox_path: str) -> int:
    total = 0
    for current_root, dirs, files in os.walk(mailbox_path):
        dirs[:] = [item for item in dirs if not os.path.islink(os.path.join(current_root, item))]
        folder = os.path.basename(current_root)
        if folder not in {"cur", "new"}:
            continue
        for filename in files:
            path = os.path.join(current_root, filename)
            if os.path.islink(path):
                continue
            try:
                total += os.path.getsize(path)
            except OSError:
                continue
    return max(0, total)

result = {}
for raw_email in mailboxes:
    email = str(raw_email).strip().lower()
    mailbox_path = safe_mailbox_path(email)
    used_bytes = maildirsize_bytes(mailbox_path)
    if used_bytes <= 0:
        used_bytes = message_file_bytes(mailbox_path)
    result[email] = {
        "used_bytes": used_bytes,
        "used_mb": int(math.ceil(used_bytes / 1048576)) if used_bytes > 0 else 0,
    }

print(json.dumps(result, ensure_ascii=False, sort_keys=True))
PY
